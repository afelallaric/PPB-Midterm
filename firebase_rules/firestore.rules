rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validMedicationFields() {
      return (
        request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.dose is string
        && request.resource.data.dose.size() <= 300
        // times must be a non-empty list (each entry should contain hour/minute client-side)
        && (request.resource.data.times is list)
        && (request.resource.data.times.size() > 0)
        && (request.resource.data.doseCount is int)
        && (request.resource.data.doseCount == request.resource.data.times.size())
        && request.resource.data.sortKey is int
        && request.resource.data.active is bool
      );
    }

    // Top-level user documents
    match /users/{userId} {
      // Medications per user
      match /medications/{medId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validMedicationFields();
        allow update: if isOwner(userId) && validMedicationFields();
        allow delete: if isOwner(userId);

        // Proofs subcollection (daily proof images metadata)
        match /proofs/{proofId} {
          function validProof() {
            return (
              request.resource.data.medicationId == medId
              && (request.resource.data.imageUrl is string || request.resource.data.localPath is string)
              && request.resource.data.dateId is string
              && request.resource.data.doseIndex is int
              && request.resource.data.takenAt is timestamp
              && request.resource.data.id == proofId
            );
          }

          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && validProof();
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
